# Database — use a hosted MySQL provider (e.g. PlanetScale, Railway, ClearDB)
DB_URL=jdbc:mysql://<host>:3306/<dbname>?useSSL=true&serverTimezone=UTC
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password

# JWT secret — must be at least 32 characters
# Generate with: openssl rand -base64 32
JWT_SECRET=replace-with-strong-random-secret

# CORS — comma-separated list of allowed client origins
ALLOWED_ORIGINS=https://your-client.onrender.com

# Twilio — optional, enables SMS order notifications
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# Notify.EU — optional, enables email order notifications
NOTIFY_SECRET_KEY=your_notify_secret_key
NOTIFY_CLIENT_ID=your_notify_client_id
NOTIFY_TEMPLATE_ID=your_notify_template_id
